{
    "name" : "Font changer",
    "version" : "1.1.0",
    "manifest_version" : 3,
    "author" : "Darrick",
    "icons" : { "32" : "iconFC.png" },
    "action" : {
        "default_popup" : "index.html"
    },
    "permissions" : ["scripting", "storage"],
    "host_permissions" : ["https://*/*", "http://*/*"],
    "content_scripts" : [
        {
            "js": ["content.js"],
            "matches": ["<all_urls>"],
            "run_at": "document_start"
        }
    ]
}
